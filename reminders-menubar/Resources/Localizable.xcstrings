    "reminderSortingDueDateOnTopNote" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud je povoleno, připomínky s termínem se vždy zobrazují jako první, seřazené podle data. Ostatní možnosti řazení se vztahují pouze na připomínky bez termínu."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn aktiviert, werden Erinnerungen mit Fälligkeitsdatum immer zuerst angezeigt, sortiert nach Datum. Andere Sortieroptionen gelten nur für Erinnerungen ohne Datum."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When enabled, reminders with a due date are always shown first, sorted by date. Other sorting options apply only to undated reminders."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando está activado, los recordatorios con fecha de vencimiento se muestran primero, ordenados por fecha. Las demás opciones de ordenación solo se aplican a los recordatorios sin fecha."
          }
        },
        "fil-PH" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kapag naka-enable, ang mga paalala na may takdang petsa ay palaging ipinapakita muna, pinagsunod-sunod ayon sa petsa. Ang iba pang mga opsyon sa pag-uuri ay nalalapat lamang sa mga paalala na walang petsa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque activé, les rappels avec une date d’échéance sont toujours affichés en premier, triés par date. Les autres options de tri ne s’appliquent qu’aux rappels sans date."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saat diaktifkan, pengingat dengan tanggal jatuh tempo selalu ditampilkan pertama, diurutkan berdasarkan tanggal. Opsi pengurutan lainnya hanya berlaku untuk pengingat tanpa tanggal."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando l’opzione è attiva, i promemoria con scadenza vengono sempre mostrati per primi, in ordine di data. Le altre opzioni di ordinamento si applicano solo ai promemoria senza scadenza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、期日のあるリマインダーが常に先に表示され、日付順に並べられます。その他の並べ替えオプションは、期日のないリマインダーにのみ適用されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "활성화하면 마감일이 있는 미리 알림이 항상 먼저 표시되며 날짜순으로 정렬됩니다. 다른 정렬 옵션은 날짜가 없는 미리 알림에만 적용됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wanneer ingeschakeld, worden herinneringen met een vervaldatum altijd eerst getoond, gesorteerd op datum. Andere sorteeropties gelden alleen voor herinneringen zonder datum."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Po włączeniu przypomnienia z terminem są zawsze wyświetlane jako pierwsze, posortowane według daty. Pozostałe opcje sortowania dotyczą tylko przypomnień bez terminu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando ativado, lembretes com data de vencimento são sempre mostrados primeiro, ordenados por data. As outras opções de ordenação se aplicam apenas aos lembretes sem data."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Когда включено, напоминания с датой выполнения всегда отображаются первыми, отсортированные по дате. Другие параметры сортировки применяются только к напоминаниям без даты."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keď je povolené, pripomienky s termínom sa vždy zobrazujú ako prvé, zoradené podľa dátumu. Ostatné možnosti zoradenia sa vzťahujú len na pripomienky bez termínu."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Etkinleştirildiğinde, bitiş tarihi olan hatırlatıcılar her zaman önce gösterilir ve tarihe göre sıralanır. Diğer sıralama seçenekleri yalnızca tarihsiz hatırlatıcılara uygulanır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Коли увімкнено, нагадування з датою виконання завжди відображаються першими, відсортовані за датою. Інші параметри сортування застосовуються лише до нагадувань без дати."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Khi được bật, lời nhắc có ngày đến hạn luôn được hiển thị trước, sắp xếp theo ngày. Các tùy chọn sắp xếp khác chỉ áp dụng cho lời nhắc không có ngày."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启用后，有截止日期的提醒事项始终排在最前面，按日期排序。其他排序选项仅适用于没有日期的提醒事项。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟用後，有截止日期的提醒事項始終排在最前面，按日期排序。其他排序選項僅適用於沒有日期的提醒事項。"
          }
        }
      }
    },
