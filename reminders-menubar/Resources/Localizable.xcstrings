    "appNoRemindersAccessAlertActionDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pro používání %@ je třeba povolit oprávnění v Systémovém nastavení."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erteilen Sie in den Systemeinstellungen die Erlaubnis zur Verwendung von %@."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grant permission in System Settings to use %@."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otorga permiso en Preferencias del Sistema para usar %@."
          }
        },
        "fil-PH" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Magbigay ng pahintulot sa System Settings upang magamit ang %@."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accordez la permission d'utiliser %@ dans les Règlages du système."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berikan izin di Pengaturan Sistem untuk menggunakan %@."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Concedi l'autorizzazione in Impostazioni di Sistema per utilizzare %@."
