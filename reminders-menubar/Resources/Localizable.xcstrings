        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "시스템 설정에서 %@ 에 대한 미리 알림 접근 권한을 허용하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verleen toestemming in Systeemvoorkeuren om %@ te gebruiken."
          }
        },
        "pl" : {
